<Bindings>
	<Binding name="TOGGLESUPERMACRO" header="SUPERMACROHEADER">
		if ( not SuperMacroFrame:IsVisible() ) then
			ShowUIPanel(SuperMacroFrame);
		else
			HideUIPanel(SuperMacroFrame);
		end;
	</Binding>
	<Binding name="OPENCHATSCRIPT">
		ChatFrame_OpenChat("/script ");
	</Binding>
	<Binding name="OPENCHATMACRO">
		ChatFrame_OpenChat("/macro ");
	</Binding>
	<Binding name="SM_ATTACK">
		SuperMacro_RunMacro("Attack");
		-- make a macro called Attack (note caps) with this body:
		-- /script if ( not PlayerFrame.inCombat ) then CastSpellByName("Attack"); end;
	</Binding>
	<Binding name="SM_PETATTACK">
		SuperMacro_RunMacro("PetAttack");
		-- make a macro called PetAttack (note caps) with this body:
		-- /script CastPetAction(1);
		-- put your pet attack icon on first slot of pet bar
	</Binding>
	<Binding name="SM_MACRO1">SuperMacro_RunMacro(1);</Binding>
